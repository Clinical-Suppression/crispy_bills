<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CrispyBills.Mobile.Android.PinSetupPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
    Title="App PIN"
    Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                Text="Protect the app with a PIN"
                TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />

            <Label
                Text="Use a simple 4-digit PIN so the app can lock when the phone has been sitting in the background."
                TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}"
                LineBreakMode="WordWrap" />

            <Border
                Padding="18"
                Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}"
                Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="PIN" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
                    <Entry
                        x:Name="PinEntry"
                        ClearButtonVisibility="WhileEditing"
                        Completed="OnPinCompleted"
                        IsPassword="True"
                        Keyboard="Numeric"
                        MaxLength="4"
                        Placeholder="4 digits"
                        TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource PlaceholderTextLight}, Dark={StaticResource MutedSubtleOnDark}}">
                        <Entry.Behaviors>
                            <local:SelectAllEntryBehavior />
                        </Entry.Behaviors>
                    </Entry>

                    <Label Text="Confirm PIN" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
                    <Entry
                        x:Name="ConfirmPinEntry"
                        ClearButtonVisibility="WhileEditing"
                        Completed="OnConfirmCompleted"
                        IsPassword="True"
                        Keyboard="Numeric"
                        MaxLength="4"
                        Placeholder="Repeat PIN"
                        TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource PlaceholderTextLight}, Dark={StaticResource MutedSubtleOnDark}}">
                        <Entry.Behaviors>
                            <local:SelectAllEntryBehavior />
                        </Entry.Behaviors>
                    </Entry>

                    <Grid x:Name="BiometricRow" ColumnDefinitions="*,Auto" IsVisible="False" Padding="0,8,0,0">
                        <Label
                            x:Name="BiometricLabel"
                            Text="Allow fingerprint/face unlock"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark={StaticResource MutedTextOnDark}}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBiometricRowTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                        <Switch
                            x:Name="BiometricSwitch"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            IsToggled="True"
                            VerticalOptions="Center" />
                    </Grid>

                    <Label
                        x:Name="StatusLabel"
                        FontSize="13"
                        IsVisible="False"
                        TextColor="{AppThemeBinding Light={StaticResource ValidationDanger}, Dark={StaticResource ValidationDangerDark}}" />
                </VerticalStackLayout>
            </Border>

            <Button
                Clicked="OnSaveClicked"
                Text="Save PIN"
                BackgroundColor="{AppThemeBinding Light={StaticResource PinAction}, Dark={StaticResource PinActionDark}}"
                TextColor="White" />

            <Button
                x:Name="CancelButton"
                Clicked="OnCancelClicked"
                Text="Not now"
                BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SecondaryButtonBgDark}}"
                TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark={StaticResource MutedTextOnDark}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
