<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrispyBills.Mobile.Android.BillEditorPage"
             Title="Bill Details">

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Label Text="Bill Name" FontAttributes="Bold" />
            <Entry x:Name="NameEntry" Placeholder="Rent, Water, Insurance..." ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Amount" FontAttributes="Bold" />
            <Entry x:Name="AmountEntry" Placeholder="0.00" Keyboard="Numeric" ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Category" FontAttributes="Bold" />
            <Picker x:Name="CategoryPicker" Title="Choose category" SelectedIndexChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Due Date" FontAttributes="Bold" />
            <DatePicker x:Name="DueDatePicker" />

            <HorizontalStackLayout Spacing="12">
                <CheckBox x:Name="PaidCheckBox" VerticalOptions="Center" />
                <Label Text="Paid" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <CheckBox x:Name="RecurringCheckBox" VerticalOptions="Center" CheckedChanged="OnRecurringChanged" />
                <Label Text="Recurring through future months" VerticalOptions="Center" />
            </HorizontalStackLayout>

            <Grid x:Name="RecurringOptionsGrid" IsVisible="False" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Every" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceEveryPicker" SelectedIndexChanged="OnInputChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>1 month</x:String>
                            <x:String>2 months</x:String>
                            <x:String>3 months</x:String>
                            <x:String>6 months</x:String>
                            <x:String>12 months</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Ends" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceEndModePicker" SelectedIndexChanged="OnEndModeChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>Never</x:String>
                            <x:String>On date</x:String>
                            <x:String>After count</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <DatePicker Grid.Row="2" x:Name="RecurrenceEndDatePicker" IsVisible="False" HeightRequest="48" />
                <Entry Grid.Row="2" x:Name="RecurrenceCountEntry" IsVisible="False" Keyboard="Numeric" Placeholder="Occurrences (e.g. 6)" HeightRequest="48" TextChanged="OnInputChanged" />
            </Grid>

            <Label x:Name="ValidationLabel" TextColor="#B42318" IsVisible="False" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked" BackgroundColor="#E5E7EB" TextColor="#111827" />
                <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
