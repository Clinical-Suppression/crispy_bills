<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrispyBills.Mobile.Android.BillEditorPage"
             Title="Bill Details">

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Label Text="Bill name" FontAttributes="Bold" FontSize="15" />
            <Entry x:Name="NameEntry" Placeholder="e.g. Rent, Electric" ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Amount" FontAttributes="Bold" FontSize="15" />
            <Entry x:Name="AmountEntry" Placeholder="0.00" Keyboard="Numeric" ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Category" FontAttributes="Bold" FontSize="15" />
            <Picker x:Name="CategoryPicker" Title="Choose category" SelectedIndexChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Due date" FontAttributes="Bold" FontSize="15" />
            <DatePicker x:Name="DueDatePicker" HeightRequest="48" />

            <HorizontalStackLayout Spacing="12">
                <Switch x:Name="PaidSwitch" VerticalOptions="Center" />
                <Label Text="Paid" VerticalOptions="Center" FontSize="16" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <Switch x:Name="RecurringSwitch" VerticalOptions="Center" Toggled="OnRecurringToggled" />
                <Label Text="Recurring in future months" VerticalOptions="Center" FontSize="16" />
            </HorizontalStackLayout>

            <Grid x:Name="RecurringOptionsGrid" IsVisible="False" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Repeat" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceFrequencyPicker" Title="How it repeats" SelectedIndexChanged="OnRecurrenceFrequencyChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>Weekly</x:String>
                            <x:String>Bi-weekly</x:String>
                            <x:String>Monthly (interval)</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8" x:Name="MonthlyIntervalRow">
                    <Label Text="Every" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceEveryPicker" SelectedIndexChanged="OnInputChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>1 month</x:String>
                            <x:String>2 months</x:String>
                            <x:String>3 months</x:String>
                            <x:String>6 months</x:String>
                            <x:String>12 months</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Ends" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceEndModePicker" SelectedIndexChanged="OnEndModeChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>Never</x:String>
                            <x:String>On date</x:String>
                            <x:String>After count</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <DatePicker Grid.Row="3" x:Name="RecurrenceEndDatePicker" IsVisible="False" HeightRequest="48" />
                <Entry Grid.Row="3" x:Name="RecurrenceCountEntry" IsVisible="False" Keyboard="Numeric" Placeholder="Occurrences (e.g. 6)" HeightRequest="48" TextChanged="OnInputChanged" />
            </Grid>

            <Label x:Name="ValidationLabel" TextColor="{StaticResource ValidationDanger}" IsVisible="False" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked" BackgroundColor="{StaticResource SurfaceLight}" TextColor="{StaticResource NeutralText}" />
                <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
