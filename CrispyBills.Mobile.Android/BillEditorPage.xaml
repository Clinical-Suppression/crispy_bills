<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
             x:Class="CrispyBills.Mobile.Android.BillEditorPage"
             Title="Bill Details"
             Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="18" Spacing="14">
            <Label Text="Bill name" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />
            <Entry x:Name="NameEntry" Placeholder="e.g. Rent, Electric" ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48">
                <Entry.Behaviors>
                    <local:SelectAllEntryBehavior />
                </Entry.Behaviors>
            </Entry>

            <Label Text="Amount" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />
            <Entry x:Name="AmountEntry" Placeholder="0.00" Keyboard="Numeric" ReturnType="Next" TextChanged="OnInputChanged" HeightRequest="48">
                <Entry.Behaviors>
                    <local:SelectAllEntryBehavior />
                </Entry.Behaviors>
            </Entry>

            <Label Text="Category" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />
            <Picker x:Name="CategoryPicker" Title="Choose category" SelectedIndexChanged="OnInputChanged" HeightRequest="48" />

            <Label Text="Due date" FontAttributes="Bold" FontSize="15" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />
            <DatePicker x:Name="DueDatePicker" DateSelected="OnDateSelected" HeightRequest="48" />

            <HorizontalStackLayout Spacing="12">
                <Switch x:Name="PaidSwitch" VerticalOptions="Center" Toggled="OnPaidSwitchToggled" />
                <Label Text="Paid" VerticalOptions="Center" FontSize="16">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPaidRowTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <Switch x:Name="RecurringSwitch" VerticalOptions="Center" Toggled="OnRecurringToggled" />
                <Label Text="Recurring" VerticalOptions="Center" FontSize="16">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRecurringRowTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

            <Grid x:Name="RecurringOptionsGrid" IsVisible="False" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Repeat" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceFrequencyPicker" Title="How it repeats" SelectedIndexChanged="OnRecurrenceFrequencyChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>Monthly</x:String>
                            <x:String>Weekly</x:String>
                            <x:String>Bi-weekly</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="8" x:Name="RecurrenceEveryMonthsGrid">
                    <Label Text="Every" VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           x:Name="RecurrenceEveryMonthsEntry"
                           Keyboard="Numeric"
                           Placeholder="Months (e.g. 3)"
                           HeightRequest="48"
                           TextChanged="OnInputChanged">
                        <Entry.Behaviors>
                            <local:SelectAllEntryBehavior />
                        </Entry.Behaviors>
                    </Entry>
                </Grid>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="Ends" VerticalOptions="Center" />
                    <Picker Grid.Column="1" x:Name="RecurrenceEndModePicker" SelectedIndexChanged="OnEndModeChanged" HeightRequest="48">
                        <Picker.Items>
                            <x:String>Never</x:String>
                            <x:String>On date</x:String>
                            <x:String>After count</x:String>
                        </Picker.Items>
                    </Picker>
                </Grid>

                <DatePicker Grid.Row="3" x:Name="RecurrenceEndDatePicker" IsVisible="False" DateSelected="OnDateSelected" HeightRequest="48" />
                <Entry Grid.Row="3" x:Name="RecurrenceCountEntry" IsVisible="False" Keyboard="Numeric" Placeholder="Occurrences (e.g. 6)" HeightRequest="48" TextChanged="OnInputChanged">
                    <Entry.Behaviors>
                        <local:SelectAllEntryBehavior />
                    </Entry.Behaviors>
                </Entry>
            </Grid>

            <Label x:Name="ValidationLabel" TextColor="{AppThemeBinding Light={StaticResource ValidationDanger}, Dark={StaticResource ValidationDangerDark}}" IsVisible="False" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked" BackgroundColor="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SecondaryButtonBgDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark={StaticResource MutedTextOnDark}}" />
                <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
