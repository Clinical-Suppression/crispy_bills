<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrispyBills.Mobile.Android.NotesPage"
             Title="Notes">

    <Grid RowDefinitions="*,Auto" Padding="14" RowSpacing="10">
        <Editor x:Name="NotesEditor"
                Grid.Row="0"
                AutoSize="TextChanges"
                Placeholder="Write your monthly reminders, payment notes, and follow-ups here..."
                FontSize="15" />

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
            <Label x:Name="LinesLabel" VerticalOptions="Center" TextColor="{StaticResource MutedText}" />
            <Button Grid.Column="2" Text="Save" Clicked="OnSaveClicked" />
        </Grid>
    </Grid>

</ContentPage>
