<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrispyBills.Mobile.Android.NotesPage"
             Title="Notes"
             Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <ScrollView>
        <Grid RowDefinitions="*,Auto" Padding="14" RowSpacing="12">
            <Editor x:Name="NotesEditor"
                    Grid.Row="0"
                    AutoSize="TextChanges"
                    Placeholder="Notes, reminders, payment follow-ups..."
                    PlaceholderColor="{AppThemeBinding Light={StaticResource PlaceholderTextLight}, Dark={StaticResource MutedSubtleOnDark}}"
                    TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}"
                    BackgroundColor="Transparent"
                    FontSize="16"
                    MinimumHeightRequest="280" />

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <Label x:Name="LinesLabel" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}" FontSize="14" />
                <Button Grid.Column="1" Text="Save" Clicked="OnSaveClicked" HeightRequest="48" />
            </Grid>
        </Grid>
    </ScrollView>

</ContentPage>
