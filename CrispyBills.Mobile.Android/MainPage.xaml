<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CrispyBills.Mobile.Android.Models"
             xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
             x:Class="CrispyBills.Mobile.Android.MainPage"
             Shell.NavBarIsVisible="False"
             Title=""
             Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <!-- Single vertical scroll: header + filters + bills. Bottom nav stays pinned. -->
    <Grid RowDefinitions="*,Auto" RowSpacing="0">

        <RefreshView x:Name="BillsRefreshView" Grid.Row="0" Refreshing="OnBillsRefreshing">
            <CollectionView x:Name="BillsCollection" SelectionMode="None">
                <CollectionView.Header>
                    <VerticalStackLayout Spacing="0">
                        <!-- Year / month -->
                        <Border StrokeThickness="0"
                                Background="{StaticResource PrimaryDarkHeaderBrush}"
                                Padding="14,10,14,8">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Button Grid.Column="0" x:Name="PrevYearButton" Text="&#x25C0;" Clicked="OnPrevYearClicked"
                                            WidthRequest="48" HeightRequest="48" Padding="0"
                                            BackgroundColor="Transparent" BorderColor="Transparent"
                                            TextColor="{StaticResource PrimaryDarkText}" />
                                    <Button Grid.Column="1" x:Name="YearButton" Clicked="OnYearSelectClicked"
                                            TextColor="{StaticResource PrimaryDarkText}" BackgroundColor="Transparent" BorderColor="Transparent"
                                            FontAttributes="Bold" FontSize="18" MinimumHeightRequest="48" />
                                    <Button Grid.Column="2" x:Name="NextYearButton" Text="&#x25B6;" Clicked="OnNextYearClicked"
                                            WidthRequest="48" HeightRequest="48" Padding="0"
                                            BackgroundColor="Transparent" BorderColor="Transparent"
                                            TextColor="{StaticResource PrimaryDarkText}" />
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <Button Grid.Column="0" Text="&#x25C0;" Clicked="OnPrevMonthClicked" WidthRequest="48" HeightRequest="48" Padding="0"
                                            BackgroundColor="Transparent" BorderColor="Transparent"
                                            TextColor="{StaticResource PrimaryDarkText}" />
                                    <Button Grid.Column="1" x:Name="MonthButton" Clicked="OnMonthSelectClicked"
                                            TextColor="{StaticResource PrimaryDarkText}" BackgroundColor="Transparent" BorderColor="Transparent"
                                            FontAttributes="Bold" FontSize="18" MinimumHeightRequest="48" />
                                    <Button Grid.Column="2" Text="&#x25B6;" Clicked="OnNextMonthClicked" WidthRequest="48" HeightRequest="48" Padding="0"
                                            BackgroundColor="Transparent" BorderColor="Transparent"
                                            TextColor="{StaticResource PrimaryDarkText}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <VerticalStackLayout Padding="14,12,14,10" Spacing="10">

                            <!-- Summary cards -->
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <Border Grid.Row="0" Grid.Column="0" x:Name="IncomeCardBorder" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="6">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnIncomeCardTapped" NumberOfTapsRequired="1" />
                                            <TapGestureRecognizer Tapped="OnIncomeCardDoubleTapped" NumberOfTapsRequired="2" />
                                        </VerticalStackLayout.GestureRecognizers>
                                        <Label Text="Income" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}" />
                                        <Label x:Name="IncomeValueLabel" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="1" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Unpaid" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}" />
                                        <Label x:Name="UnpaidLabel" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="0" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Remaining" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}" />
                                        <Label x:Name="RemainingLabel" FontSize="20" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="Bills" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}" />
                                        <Label x:Name="BillCountLabel" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>

                            <GraphicsView x:Name="IncomeExpenseBarView" HeightRequest="28">
                                <GraphicsView.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnIncomeExpenseBarTapped" />
                                </GraphicsView.GestureRecognizers>
                            </GraphicsView>

                            <!-- Swipe hint + action pills -->
                            <VerticalStackLayout Spacing="6">
                                <!-- MAUI SwipeView: swipe content left reveals RightItems (Delete); swipe right reveals LeftItems (Paid/Unpaid). -->
                                <Label Text="Tip: Swipe left/right with a deliberate drag to delete or toggle paid. Double-tap the bill row text area to edit (or double-tap the income card)."
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}"
                                       LineBreakMode="WordWrap"
                                       Margin="0,0,0,2" />
                                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                    <HorizontalStackLayout Spacing="10" Padding="0,4">
                                        <Button x:Name="RolloverUnpaidButton" Text="Rollover Unpaid (debug)" Clicked="OnRolloverClicked" Padding="16,12" CornerRadius="20" FontSize="13" IsVisible="False" />
                                        <Button Text="New Year" Clicked="OnNewYearClicked" Padding="16,12" CornerRadius="20" FontSize="13" />
                                        <Button Text="Archive" Clicked="OnArchiveYearClicked" Padding="16,12" CornerRadius="20" FontSize="13" />
                                        <Button Text="Import" Clicked="OnImportClicked" Padding="16,12" CornerRadius="20" FontSize="13" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
                                        <Button Text="Export" Clicked="OnExportClicked" Padding="16,12" CornerRadius="20" FontSize="13" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
                                    </HorizontalStackLayout>
                                </ScrollView>
                            </VerticalStackLayout>

                            <!-- Search + category -->
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <Entry x:Name="SearchEntry" Placeholder="Search bills..." TextChanged="OnSearchChanged" HeightRequest="48">
                                    <Entry.Behaviors>
                                        <local:SelectAllEntryBehavior />
                                    </Entry.Behaviors>
                                </Entry>
                                <Picker x:Name="CategoryPicker" Grid.Column="1" Title="Category" SelectedIndexChanged="OnCategoryChanged" HeightRequest="48" />
                                <Picker x:Name="SortPicker" Grid.Column="2" Title="Sort" SelectedIndexChanged="OnSortChanged" HeightRequest="48" />
                            </Grid>

                            <Button x:Name="BillsListAddButton"
                                    Text="Add bill(s)"
                                    Clicked="OnAddClicked"
                                    Padding="16,12"
                                    CornerRadius="20"
                                    FontSize="13"
                                    HorizontalOptions="Start"
                                    IsVisible="False" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="24,32" Spacing="16" HorizontalOptions="Center">
                        <Label x:Name="EmptyStateTitleLabel" Text="No bills yet" HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource EmptyText}, Dark={StaticResource Gray100}}" />
                        <Label x:Name="EmptyStateSubtitleLabel" Text="Swipe left/right with a deliberate drag to delete or toggle paid/unpaid. Double-tap a bill row to edit." HorizontalOptions="Center" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource MutedLight}, Dark={StaticResource MutedTextOnDark}}" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                        <Button x:Name="EmptyAddBillsButton" Text="Add your first bill(s)" Clicked="OnAddClicked" HorizontalOptions="Center" Padding="24,14" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:BillListItem">
                        <!-- Double-tap on SwipeView content (inner Border) to edit—avoids parent/child gesture arbitration with SwipeView. Threshold in MAUI DI units. -->
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding CardRowBackground}"
                                StrokeShape="RoundRectangle 14"
                                Padding="0"
                                Margin="14,0,14,10">
                            <!-- 300: minimum horizontal drag before paid/delete Execute; reduces accidental swipe vs double-tap/scroll. -->
                            <SwipeView Threshold="300">
                                <!-- Revealed when user swipes content to the right (finger moves right). -->
                                <SwipeView.LeftItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItem Text="Paid / Unpaid"
                                                   BackgroundColor="{StaticResource Success}"
                                                   Invoked="OnSwipeTogglePaid" />
                                    </SwipeItems>
                                </SwipeView.LeftItems>
                                <!-- Revealed when user swipes content to the left (finger moves left). -->
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="{AppThemeBinding Light={StaticResource Danger}, Dark={StaticResource DangerDark}}"
                                                   Invoked="OnSwipeDelete" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Border StrokeThickness="0" Padding="14" BackgroundColor="Transparent" VerticalOptions="Fill">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBillRowDoubleTapped" NumberOfTapsRequired="2" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="17" LineBreakMode="TailTruncation" HorizontalOptions="FillAndExpand" TextColor="{Binding PrimaryRowTextColor}" />
                                                <Label Text="{Binding AmountDisplay}" FontAttributes="Bold" FontSize="17" TextColor="{Binding PrimaryRowTextColor}" />
                                            </HorizontalStackLayout>
                                            <Label Text="{Binding Category}" TextColor="{Binding SecondaryRowTextColor}" FontSize="13" />
                                            <Label Text="{Binding DueDate, StringFormat='Due {0:MMM d}'}" TextColor="{Binding SecondaryRowTextColor}" FontSize="13" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1"
                                                StrokeThickness="0"
                                                Padding="12,8"
                                                MinimumHeightRequest="36"
                                                BackgroundColor="Transparent"
                                                StrokeShape="RoundRectangle 999"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding StatusText}" FontSize="12" TextColor="{Binding StatusBadgeTextColor}" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Bottom nav -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="8" Padding="14,8,14,10">
            <Button Grid.Column="0" Text="Summary" Clicked="OnSummaryClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
            <Button Grid.Column="1" Text="Notes" Clicked="OnNotesClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
            <Button Grid.Column="2" Text="Settings" Clicked="OnSettingsClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
            <Button Grid.Column="3" Text="Help" Clicked="OnHelpClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}" />
        </Grid>
    </Grid>
</ContentPage>
