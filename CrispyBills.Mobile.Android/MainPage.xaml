<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CrispyBills.Mobile.Android.Models"
             xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
             x:Class="CrispyBills.Mobile.Android.MainPage"
             Shell.NavBarIsVisible="False"
             Title="Crispy Bills"
             Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- Header -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                Background="{StaticResource PrimaryDarkHeaderBrush}"
                Padding="14,16,14,14">
            <VerticalStackLayout Spacing="14">
                <Label Text="Crispy Bills"
                       TextColor="{StaticResource White}"
                       FontSize="22"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0" x:Name="PrevYearButton" Text="&#x25C0;" Clicked="OnPrevYearClicked"
                            WidthRequest="48" HeightRequest="48" Padding="0" />
                    <Button Grid.Column="1" x:Name="YearButton" Clicked="OnYearSelectClicked"
                            TextColor="White" BackgroundColor="Transparent" BorderColor="Transparent"
                            FontAttributes="Bold" FontSize="18" MinimumHeightRequest="48" />
                    <Button Grid.Column="2" x:Name="NextYearButton" Text="&#x25B6;" Clicked="OnNextYearClicked"
                            WidthRequest="48" HeightRequest="48" Padding="0" />
                    <Button Grid.Column="3" Text="Archive" Clicked="OnArchiveYearClicked" HeightRequest="48" FontSize="13" Padding="12,8" />
                </Grid>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Button Grid.Column="0" Text="&#x25C0;" Clicked="OnPrevMonthClicked" WidthRequest="48" HeightRequest="48" Padding="0" />
                    <Button Grid.Column="1" x:Name="MonthButton" Clicked="OnMonthSelectClicked"
                            TextColor="White" BackgroundColor="Transparent" BorderColor="Transparent"
                            FontAttributes="Bold" FontSize="18" MinimumHeightRequest="48" />
                    <Button Grid.Column="2" Text="&#x25B6;" Clicked="OnNextMonthClicked" WidthRequest="48" HeightRequest="48" Padding="0" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- Body + bottom bar -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="10" Padding="14,12,14,10">

            <!-- Summary cards -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Income" FontSize="12" TextColor="{StaticResource MutedText}" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Entry Grid.Column="0"
                                   x:Name="IncomeEntry"
                                   Placeholder="0.00"
                                   Keyboard="Numeric"
                                   Completed="OnIncomeEntryCompleted"
                                   Unfocused="OnIncomeEntryUnfocused"
                                   HeightRequest="48">
                                <Entry.Behaviors>
                                    <local:SelectAllEntryBehavior />
                                </Entry.Behaviors>
                            </Entry>
                            <Picker Grid.Column="1"
                                    x:Name="IncomePayPeriodPicker"
                                    Title="Pay period"
                                    SelectedIndexChanged="OnIncomePayPeriodChanged"
                                    WidthRequest="140"
                                    HeightRequest="48" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Unpaid" FontSize="12" TextColor="{StaticResource MutedText}" />
                        <Label x:Name="UnpaidLabel" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource Danger}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Remaining" FontSize="12" TextColor="{StaticResource MutedText}" />
                        <Label x:Name="RemainingLabel" FontSize="20" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" Padding="12" StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Bills" FontSize="12" TextColor="{StaticResource MutedText}" />
                        <Label x:Name="BillCountLabel" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Month income vs bill totals -->
            <VerticalStackLayout Grid.Row="1" Spacing="4">
                <Label x:Name="IncomeExpenseBarCaption"
                       FontSize="11"
                       TextColor="{StaticResource MutedText}"
                       LineBreakMode="WordWrap" />
                <GraphicsView x:Name="IncomeExpenseBarView" HeightRequest="28" />
            </VerticalStackLayout>

            <!-- Swipe hint + action pills -->
            <VerticalStackLayout Grid.Row="2" Spacing="6">
                <Label Text="Tip: Swipe a bill left to mark paid or unpaid. Swipe right for Edit and Delete."
                       FontSize="12"
                       TextColor="{StaticResource MutedText}"
                       LineBreakMode="WordWrap"
                       Margin="0,0,0,2" />
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="10" Padding="0,4">
                    <Button Text="Rollover" Clicked="OnRolloverClicked" Padding="16,12" CornerRadius="20" FontSize="13" />
                    <Button Text="New Year" Clicked="OnNewYearClicked" Padding="16,12" CornerRadius="20" FontSize="13" />
                    <Button Text="Import" Clicked="OnImportClicked" Padding="16,12" CornerRadius="20" FontSize="13" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{StaticResource NeutralText}" />
                    <Button Text="Export" Clicked="OnExportClicked" Padding="16,12" CornerRadius="20" FontSize="13" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{StaticResource NeutralText}" />
                </HorizontalStackLayout>
            </ScrollView>
            </VerticalStackLayout>

            <!-- Search + category -->
            <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10">
                <Entry x:Name="SearchEntry" Placeholder="Search bills..." TextChanged="OnSearchChanged" HeightRequest="48">
                    <Entry.Behaviors>
                        <local:SelectAllEntryBehavior />
                    </Entry.Behaviors>
                </Entry>
                <Picker x:Name="CategoryPicker" Grid.Column="1" Title="Category" SelectedIndexChanged="OnCategoryChanged" HeightRequest="48" />
            </Grid>

            <!-- Bill list: add button only when month has bills (see UpdateAddButtonText) -->
            <Grid Grid.Row="4" RowDefinitions="Auto,*" RowSpacing="8">
                <Button Grid.Row="0"
                        x:Name="BillsListAddButton"
                        Text="Add bill(s)"
                        Clicked="OnAddClicked"
                        Padding="16,12"
                        CornerRadius="20"
                        FontSize="13"
                        HorizontalOptions="Start"
                        IsVisible="False" />
                <RefreshView x:Name="BillsRefreshView" Grid.Row="1" Refreshing="OnBillsRefreshing">
                <CollectionView x:Name="BillsCollection" SelectionMode="None" Margin="0,4,0,0">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="24,32" Spacing="16" HorizontalOptions="Center">
                            <Label Text="No bills yet" HorizontalOptions="Center" FontSize="18" TextColor="{StaticResource EmptyText}" />
                            <Label Text="Swipe left on a bill to toggle paid. Swipe right for edit or delete." HorizontalOptions="Center" FontSize="13" TextColor="{StaticResource MutedLight}" HorizontalTextAlignment="Center" />
                            <Button x:Name="EmptyAddBillsButton" Text="Add your first bill(s)" Clicked="OnAddClicked" HorizontalOptions="Center" Padding="24,14" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:BillListItem">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{Binding CardRowBackground}"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="0"
                                    Margin="0,0,0,10">
                                <SwipeView>
                                    <SwipeView.LeftItems>
                                        <SwipeItems Mode="Execute">
                                            <SwipeItem Text="Paid"
                                                       BackgroundColor="{StaticResource Success}"
                                                       Invoked="OnSwipeTogglePaid" />
                                        </SwipeItems>
                                    </SwipeView.LeftItems>
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItem Text="Edit"
                                                       BackgroundColor="{StaticResource Info}"
                                                       Invoked="OnSwipeEdit" />
                                            <SwipeItem Text="Delete"
                                                       BackgroundColor="{StaticResource Danger}"
                                                       Invoked="OnSwipeDelete" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Border StrokeThickness="0" Padding="14" BackgroundColor="Transparent">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="6">
                                                <VerticalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnBillCardTapped" />
                                                </VerticalStackLayout.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="17" LineBreakMode="TailTruncation" HorizontalOptions="FillAndExpand" TextColor="{StaticResource NeutralText}" />
                                                    <Label Text="{Binding AmountDisplay}" FontAttributes="Bold" FontSize="17" TextColor="{StaticResource NeutralText}" />
                                                </HorizontalStackLayout>
                                                <Label Text="{Binding Category}" TextColor="{StaticResource MutedText}" FontSize="13" />
                                                <Label Text="{Binding DueDate, StringFormat='Due {0:MMM d}'}" TextColor="{StaticResource MutedText}" FontSize="13" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1"
                                                    StrokeThickness="0"
                                                    Padding="12,8"
                                                    MinimumHeightRequest="36"
                                                    BackgroundColor="Transparent"
                                                    StrokeShape="RoundRectangle 999"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding StatusText}" FontSize="12" TextColor="{Binding StatusBadgeTextColor}" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
            </Grid>

            <!-- Bottom nav -->
            <Grid Grid.Row="5" ColumnDefinitions="*,*,*" ColumnSpacing="8" Padding="0,8,0,0">
                <Button Grid.Column="0" Text="Summary" Clicked="OnSummaryClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{StaticResource NeutralText}" />
                <Button Grid.Column="1" Text="Notes" Clicked="OnNotesClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{StaticResource NeutralText}" />
                <Button Grid.Column="2" Text="Settings" Clicked="OnSettingsClicked" HeightRequest="52" Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}" TextColor="{StaticResource NeutralText}" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
