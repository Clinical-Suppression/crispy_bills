<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CrispyBills.Mobile.Android.UnlockPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="{AppThemeBinding Light=#FFF7E6, Dark=#1F1F1F}">

    <ScrollView>
        <VerticalStackLayout Padding="24,48" Spacing="18">
            <Label
                FontAttributes="Bold"
                FontSize="26"
                HorizontalOptions="Center"
                Text="Unlock Crispy Bills"
                TextColor="{AppThemeBinding Light=#3A2400, Dark=White}" />

            <Label
                HorizontalTextAlignment="Center"
                Text="Enter your 4-digit PIN to view your bills."
                TextColor="{AppThemeBinding Light=#5C4A2D, Dark=#DDDDDD}" />

            <Frame
                Padding="18"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                BorderColor="{AppThemeBinding Light=#F1D5A0, Dark=#4A4A4A}"
                CornerRadius="16"
                HasShadow="False">
                <VerticalStackLayout Spacing="12">
                    <Entry
                        x:Name="PinEntry"
                        ClearButtonVisibility="WhileEditing"
                        Completed="OnPinEntryCompleted"
                        TextChanged="OnPinEntryTextChanged"
                        FontSize="24"
                        HorizontalTextAlignment="Center"
                        IsPassword="True"
                        Keyboard="Numeric"
                        MaxLength="4"
                        Placeholder="••••">
                        <Entry.Behaviors>
                            <local:SelectAllEntryBehavior />
                        </Entry.Behaviors>
                    </Entry>

                    <Label
                        x:Name="StatusLabel"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        IsVisible="False"
                        TextColor="#B42318" />

                    <Button
                        x:Name="BiometricButton"
                        Clicked="OnBiometricClicked"
                        IsVisible="False"
                        Text="Use fingerprint or face"
                        BackgroundColor="#E8F0FE"
                        TextColor="#163A6B" />

                    <Button
                        Clicked="OnUnlockClicked"
                        Text="Unlock"
                        BackgroundColor="#D97706"
                        TextColor="White" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
