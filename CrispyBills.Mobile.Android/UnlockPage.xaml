<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CrispyBills.Mobile.Android.UnlockPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
    NavigationPage.HasNavigationBar="False"
    Background="{AppThemeBinding Light={StaticResource PageBackgroundBrush}, Dark={StaticResource PageBackgroundBrushDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="24,48" Spacing="18">
            <Label
                FontAttributes="Bold"
                FontSize="26"
                HorizontalOptions="Center"
                Text="Unlock Crispy Bills"
                TextColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark=White}" />

            <Label
                HorizontalTextAlignment="Center"
                Text="Enter your 4-digit PIN to view your bills."
                TextColor="{AppThemeBinding Light={StaticResource MutedText}, Dark={StaticResource MutedTextOnDark}}"
                LineBreakMode="WordWrap" />

            <Border
                Padding="18"
                Background="{AppThemeBinding Light={StaticResource SurfaceGlassBrushLight}, Dark={StaticResource SurfaceGlassBrushDark}}"
                Stroke="{AppThemeBinding Light={StaticResource SurfaceStrokeLightBrush}, Dark={StaticResource SurfaceStrokeDarkBrush}}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">
                <VerticalStackLayout Spacing="12">
                    <Entry
                        x:Name="PinEntry"
                        ClearButtonVisibility="WhileEditing"
                        Completed="OnPinEntryCompleted"
                        TextChanged="OnPinEntryTextChanged"
                        FontSize="24"
                        HorizontalTextAlignment="Center"
                        IsPassword="True"
                        Keyboard="Numeric"
                        MaxLength="4"
                        Placeholder="••••"
                        TextColor="{AppThemeBinding Light={StaticResource NeutralText}, Dark=White}"
                        PlaceholderColor="{AppThemeBinding Light={StaticResource PlaceholderTextLight}, Dark={StaticResource MutedSubtleOnDark}}">
                        <Entry.Behaviors>
                            <local:SelectAllEntryBehavior />
                        </Entry.Behaviors>
                    </Entry>

                    <Label
                        x:Name="StatusLabel"
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        IsVisible="False"
                        TextColor="{AppThemeBinding Light={StaticResource ValidationDanger}, Dark={StaticResource ValidationDangerDark}}" />

                    <Button
                        x:Name="BiometricButton"
                        Clicked="OnBiometricClicked"
                        IsVisible="False"
                        Text="Use fingerprint or face"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PinBiometricButtonBgLight}, Dark={StaticResource PinBiometricButtonBgDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource PinBiometricButtonTextLight}, Dark={StaticResource PinBiometricButtonTextDark}}" />

                    <Button
                        Clicked="OnUnlockClicked"
                        Text="Unlock"
                        BackgroundColor="{AppThemeBinding Light={StaticResource PinAction}, Dark={StaticResource PinActionDark}}"
                        TextColor="White" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
