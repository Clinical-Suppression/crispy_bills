<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CrispyBills.Mobile.Android.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CrispyBills.Mobile.Android"
    Title="Crispy Bills"
    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray950}}"
    ForegroundColor="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource White}}">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

</Shell>
