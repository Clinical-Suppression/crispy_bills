<Window x:Class="CrispyBills.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crispy Bills Help"
        Height="560" Width="680"
        MinHeight="420" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Crispy Bills Help" FontWeight="Bold" FontSize="{DynamicResource BaseFontSize}" Margin="0,0,0,8"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Editing bills" FontWeight="Bold" Margin="0,4,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Double-click a row in the grid to toggle its paid status. Use the Edit button or right-click to open the full bill editor with recurrence options. Press Tab or Enter to move between cells for inline editing."/>

                <TextBlock Text="Adding bills" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Use the Add Bill button for a single bill with full recurrence options (monthly, weekly, bi-weekly, every N months, end rules). Use Bulk Add to enter up to 75 bills at once in a grid."/>

                <TextBlock Text="Paid / Unpaid" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Click the Status cell in the grid to toggle between Paid and Due. Paid bills appear with a green tint; past-due bills appear with a red tint."/>

                <TextBlock Text="Deleting bills" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Select a bill row and click Delete, or use the Delete key. Deleting a recurring bill removes all future copies in the same series."/>

                <TextBlock Text="Income" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Enter your income in the Income box and press Enter or click away. The value is applied from the selected month through December of the current year."/>

                <TextBlock Text="New Year" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Creates the next calendar year from December's recurring templates. Recurring bills use a January-anchored phase for 'every N months' intervals. Unpaid items carry forward as 'Name - December' rows in January. Income from December is copied to all 12 months. New Year is manual—it does not run automatically on January 1."/>

                <TextBlock Text="Rollover" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Moves unpaid bills from the selected month to the next month within the same year. Cannot roll December into the next year—use New Year for that. Rollover creates a copy with a renamed suffix (e.g. 'Rolled over from January')."/>

                <TextBlock Text="Import / Export" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Export saves a structured CSV file with all bills and income for the current year. Import lets you select specific years and months from a CSV file to bring into the app. You can also choose to import notes."/>

                <TextBlock Text="Search and filter" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Use the search box in the toolbar to filter bills by name or category. Use the category dropdown to show only one category. Clear the search to see all bills again."/>

                <TextBlock Text="Undo / Redo" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Press Ctrl+Z to undo or Ctrl+Y to redo. The undo stack holds up to 500 actions. Undo covers bill edits, deletions, income changes, and rollover operations."/>

                <TextBlock Text="Keyboard shortcuts" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Ctrl+S: Save  |  Ctrl+Z: Undo  |  Ctrl+Y: Redo  |  Delete: Remove selected bill  |  Enter: Confirm inline edit (with 'Enter moves down' enabled, moves to next row)"/>

                <TextBlock Text="Notes" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="The notes panel on the right side of the main window is saved automatically as you type. Notes are limited to 500 lines and are shared across all years."/>

                <TextBlock Text="Debug tools" FontWeight="Bold" Margin="0,8,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.9" Margin="0,0,0,8"
                           Text="Debug tools (Delete Month, Delete Year) are hidden by default. Enable them from the Debug menu. These are destructive operations intended for testing and repair only."/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Close" Width="88" IsCancel="True" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
