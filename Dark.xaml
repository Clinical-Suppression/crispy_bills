<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FF202020</Color>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}"/>

    <Color x:Key="WindowForegroundColor">#FFF0F0F0</Color>
    <SolidColorBrush x:Key="WindowForegroundBrush" Color="{StaticResource WindowForegroundColor}"/>

    <Color x:Key="ControlBackgroundColor">#FF2A2A2A</Color>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{StaticResource ControlBackgroundColor}"/>

    <Color x:Key="ControlForegroundColor">#FFF0F0F0</Color>
    <SolidColorBrush x:Key="ControlForegroundBrush" Color="{StaticResource ControlForegroundColor}"/>

    <Color x:Key="PanelBackgroundColor">#FF262626</Color>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}"/>

    <Color x:Key="PanelBorderColor">#FF3C3C3C</Color>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}"/>

    <Color x:Key="HintForegroundColor">#FF9A9A9A</Color>
    <SolidColorBrush x:Key="HintForegroundBrush" Color="{StaticResource HintForegroundColor}"/>

    <Color x:Key="AccentColor">#FF6CC644</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>

    <SolidColorBrush x:Key="ExpenseBarBrush" Color="#FF6CC644"/>

    <!-- Notes area colors -->
    <SolidColorBrush x:Key="NotesAreaBackgroundBrush" Color="#AA2D3428"/>
    <SolidColorBrush x:Key="NotesAreaBorderBrush" Color="#FF4E5B45"/>
    <SolidColorBrush x:Key="NotesHeaderBrush" Color="#FFE5E9D8"/>
    <SolidColorBrush x:Key="NotesTextBrush" Color="#FFF4F7EA"/>
    <SolidColorBrush x:Key="NotebookPaperBrush" Color="#CC2A3025"/>

    <!-- System menu brush overrides for submenu popup readability -->
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#FF262626"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF6CC644"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF111111"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF2A2A2A"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FF262626"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#FFF0F0F0"/>

    <!-- WPF default menu template keys used by submenu popups -->
    <SolidColorBrush x:Key="Menu.Static.Background" Color="#FF262626"/>
    <SolidColorBrush x:Key="Menu.Static.Border" Color="#FF3C3C3C"/>
    <SolidColorBrush x:Key="Menu.Static.Foreground" Color="#FFF0F0F0"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Background" Color="#FF3B4A34"/>
    <SolidColorBrush x:Key="MenuItem.Highlight.Border" Color="#FF6CC644"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Background" Color="#FF3B4A34"/>
    <SolidColorBrush x:Key="MenuItem.Selected.Border" Color="#FF6CC644"/>
    <SolidColorBrush x:Key="MenuItem.Disabled.Foreground" Color="#FF7A7A7A"/>
    <SolidColorBrush x:Key="MenuItem.Submenu.Background" Color="#FF262626"/>
    <SolidColorBrush x:Key="MenuItem.Submenu.Border" Color="#FF3C3C3C"/>
    <SolidColorBrush x:Key="MenuItem.Separator.Background" Color="#FF3A3A3A"/>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WindowForegroundBrush}"/>
    </Style>

    <!-- Basic control defaults to match the theme -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
    </Style>

    <Style TargetType="Calendar">
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
    </Style>
    <Style TargetType="CalendarDayButton">
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
    </Style>
    <Style TargetType="CalendarButton">
        <Setter Property="Foreground" Value="#FFFFFFFF"/>
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
    </Style>

    <!-- DataGrid defaults -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource ControlBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}"/>
        <Setter Property="RowBackground" Value="#FF2A2A2A"/>
        <Setter Property="AlternatingRowBackground" Value="#FF303030"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
    </Style>

    <Style TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WindowForegroundBrush}"/>
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WindowForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource WindowForegroundBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsHighlighted" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground" Value="White"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>