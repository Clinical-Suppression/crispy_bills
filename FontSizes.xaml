<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Base Font Size -->
    <system:Double x:Key="BaseFontSize">18</system:Double>
    <system:Double x:Key="DataGridRowMinHeight">30</system:Double>
    <system:Double x:Key="DataGridHeaderHeight">34</system:Double>

    <Style TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="Menu" BasedOn="{StaticResource {x:Type Menu}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="ContextMenu" BasedOn="{StaticResource {x:Type ContextMenu}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
    <Style TargetType="DataGridRow">
        <Setter Property="MinHeight" Value="{DynamicResource DataGridRowMinHeight}" />
    </Style>
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Height" Value="{DynamicResource DataGridHeaderHeight}" />
        <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}" />
    </Style>
</ResourceDictionary>
