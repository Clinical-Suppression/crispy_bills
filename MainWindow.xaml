<Window x:Class="CrispyBills.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Crispy Bills" Height="920" Width="1460" MinWidth="1240" MinHeight="760"
        SizeToContent="Manual"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewMouseDown="Window_PreviewMouseDown"
        Deactivated="Window_Deactivated">

    <!-- Command &amp; Input bindings for common keyboard shortcuts -->
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveCommand_Executed" />
        <CommandBinding Command="ApplicationCommands.Undo" Executed="UndoCommand_Executed" CanExecute="UndoCommand_CanExecute" />
        <CommandBinding Command="ApplicationCommands.Redo" Executed="RedoCommand_Executed" CanExecute="RedoCommand_CanExecute" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Command="ApplicationCommands.Save" Gesture="Ctrl+S"/>
        <KeyBinding Command="ApplicationCommands.Undo" Gesture="Ctrl+Z"/>
        <KeyBinding Command="ApplicationCommands.Redo" Gesture="Ctrl+Y"/>
    </Window.InputBindings>

    <Window.Resources>
        <!-- Common spacing -->
        <Thickness x:Key="ControlMargin">0,0,8,0</Thickness>
        <x:Array x:Key="BillCategories" Type="{x:Type sys:String}">
            <sys:String>General</sys:String>
            <sys:String>Housing</sys:String>
            <sys:String>Utilities</sys:String>
            <sys:String>Groceries</sys:String>
            <sys:String>Transportation</sys:String>
            <sys:String>Insurance</sys:String>
            <sys:String>Healthcare</sys:String>
            <sys:String>Entertainment</sys:String>
            <sys:String>Subscriptions</sys:String>
            <sys:String>Savings</sys:String>
            <sys:String>Debt</sys:String>
            <sys:String>Education</sys:String>
            <sys:String>Personal Care</sys:String>
            <sys:String>Miscellaneous</sys:String>
        </x:Array>
        <Style x:Key="RightAlignedCell" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Padding" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="GridTextEditStyle" TargetType="TextBox">
            <EventSetter Event="KeyDown" Handler="GridTextEditBox_KeyDown"/>
        </Style>

        <Style x:Key="GridDueDateEditStyle" TargetType="TextBox">
            <EventSetter Event="PreviewKeyDown" Handler="DueDateTextBox_KeyDown"/>
            <EventSetter Event="PreviewTextInput" Handler="DueDateTextBox_PreviewTextInput"/>
            <EventSetter Event="DataObject.Pasting" Handler="DueDateTextBox_Pasting"/>
        </Style>

        <Style x:Key="GridComboEditStyle" TargetType="ComboBox">
            <EventSetter Event="GotKeyboardFocus" Handler="GridComboEdit_GotKeyboardFocus"/>
            <EventSetter Event="LostKeyboardFocus" Handler="GridComboEdit_LostKeyboardFocus"/>
            <EventSetter Event="KeyDown" Handler="GridComboEdit_KeyDown"/>
            <EventSetter Event="SelectionChanged" Handler="GridComboEdit_SelectionChanged"/>
        </Style>

        <!-- Simple flat button style -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Margin" Value="{StaticResource ControlMargin}"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <!-- subtle hover that works on both light/dark -->
                    <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                    <Setter Property="Opacity" Value="0.95"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small search watermark overlay — non-invasive to TextBox text or undo stack -->
        <Style x:Key="SearchBoxContainer" TargetType="Grid">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Small section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- Force themed submenu popups instead of OS default colors -->
        <Style x:Key="AppMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource BaseFontSize}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="HeaderHost"
                                                  Grid.Column="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  Margin="8,2,8,2"
                                                  VerticalAlignment="Center"/>

                                <TextBlock x:Name="GestureText"
                                           Grid.Column="1"
                                           Margin="12,2,8,2"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{TemplateBinding Foreground}"/>

                                <Path x:Name="Arrow"
                                      Grid.Column="2"
                                      Margin="8,0,8,0"
                                      VerticalAlignment="Center"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M 0 0 L 4 3.5 L 0 7 Z"
                                      Visibility="Collapsed"/>

                                <Popup x:Name="SubMenuPopup"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{TemplateBinding IsSubmenuOpen}"
                                       PopupAnimation="Fade">
                                    <Border Background="{DynamicResource PanelBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="1"
                                            Padding="2">
                                        <ScrollViewer CanContentScroll="True"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Auto">
                                            <StackPanel IsItemsHost="True"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="OuterBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="Transparent"/>
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="SubMenuPopup" Property="Placement" Value="Bottom"/>
                            </Trigger>

                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="GestureText" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="Role" Value="SubmenuItem">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>

                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource HintForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource AppMenuItemStyle}"/>

    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Main Menu -->
        <Menu DockPanel.Dock="Top" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_New Year" Click="NewYear_Click"/>
                <MenuItem Header="_Save" Click="Save_Click" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Import CSV..." Click="ImportCsv_Click"/>
                <MenuItem Header="Export _CSV..." Click="ExportCsv_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Click="Undo_Click" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Click="Redo_Click" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Add Bill..." Click="OpenAddDialog_Click"/>
                <MenuItem Header="_Rollover Unpaid..." Click="Rollover_Click"/>
                <Separator/>
                <MenuItem Header="_Fix Due Dates (Current Year)..." Click="FixDueDatesCurrentYear_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Theme" Click="ToggleTheme_Click"/>
                <MenuItem Header="_Monthly Summary" Click="SendSummary_Click"/>
                <MenuItem Header="_Enter Moves Down" IsCheckable="True" Click="EnterMovesDown_Click"/>
                <Separator/>
                <MenuItem Header="Text _Size">
                    <MenuItem Header="_Small" Click="SetFontSize_Small" />
                    <MenuItem Header="_Medium" Click="SetFontSize_Medium" />
                    <MenuItem Header="_Large" Click="SetFontSize_Large" />
                </MenuItem>
                <Separator/>
                <MenuItem Header="Grid Edit _Checklist" Click="GridEditChecklist_Click"/>
            </MenuItem>
        </Menu>

        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBackgroundBrush}" Padding="8" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: year controls + month + search -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Year:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="YearSelector" Width="80" SelectionChanged="YearSelector_SelectionChanged" VerticalAlignment="Center" IsEditable="False"/>
                        <Button x:Name="NewYearBtn" Content="New Year" Click="NewYear_Click" Style="{StaticResource ToolbarButton}" Margin="6,0,0,0" ToolTip="Create the next year (copies recurring December bills)"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Month:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="MonthSelector"
                                  Width="140"
                                  VerticalAlignment="Center"
                                  AutomationProperties.Name="Month selector"
                                  IsEditable="False"
                                  SelectionChanged="MonthSelector_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Category:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ComboBox x:Name="CategoryFilter"
                                  Width="140"
                                  VerticalAlignment="Center"
                                  AutomationProperties.Name="Category filter"
                                  IsEditable="False"
                                  SelectionChanged="CategoryFilter_SelectionChanged"/>
                    </StackPanel>

                    <Grid x:Name="SearchBoxContainerGrid" Style="{StaticResource SearchBoxContainer}" VerticalAlignment="Center" Width="278" Height="28">
                        <TextBox x:Name="SearchBox"
                                 Width="278"
                                 Margin="0"
                                 TextChanged="SearchBox_TextChanged"
                                 VerticalContentAlignment="Center"
                                 Padding="6,2,28,2"
                                 AutomationProperties.Name="Search bills"
                                 Background="{DynamicResource ControlBackgroundBrush}"
                                 Foreground="{DynamicResource ControlForegroundBrush}"/>
                        <TextBlock Text="Search bills..."
                                   Foreground="{DynamicResource HintForegroundBrush}"
                                   Margin="10,0,8,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Clear search button -->
                        <Button x:Name="ClearSearchBtn"
                            Width="20" Height="20"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                            Margin="0,0,4,0"
                                ToolTip="Clear search"
                                Click="ClearSearch_Click"
                                Content="✕"
                            FontSize="11"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="{DynamicResource HintForegroundBrush}" />
                    </Grid>
                </StackPanel>

                <!-- Right: controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Column="2" VerticalAlignment="Center">
                    <Button Content="Export CSV" Click="ExportCsv_Click" Style="{StaticResource ToolbarButton}" ToolTip="Export the entire current year to a single CSV file" />
                    <Button Content="Import CSV" Click="ImportCsv_Click" Style="{StaticResource ToolbarButton}" ToolTip="Import CSV into current month" />
                    <Button Content="Summary" Click="SendSummary_Click" Style="{StaticResource ToolbarButton}" ToolTip="View monthly summary report" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,0,0" Padding="6">
            <TextBlock x:Name="StatusText" Foreground="{DynamicResource HintForegroundBrush}" Text="Ready" />
        </StatusBar>

        <!-- Main content: two columns (bills area, right chart) -->
        <Grid Margin="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Center area: income + grid (left/large) -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock Text="Income:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="IncomeBox"
                             Width="140"
                             KeyDown="IncomeBox_KeyDown"
                             LostFocus="IncomeBox_LostFocus"
                             VerticalContentAlignment="Center"
                             Padding="6,2"
                             Background="{DynamicResource ControlBackgroundBrush}"
                             Foreground="{DynamicResource ControlForegroundBrush}"/>
                    <Button Content="Rollover" Click="Rollover_Click" Margin="8,0,0,0" ToolTip="Roll unpaid bills forward" />
                    <Button Content="Add" Click="OpenAddDialog_Click" Margin="8,0,0,0" ToolTip="Add new bill" />
                    <Button Content="Edit" Click="EditBill_Click" Margin="8,0,0,0" ToolTip="Edit selected bill" />
                    <Button Content="Delete" Click="DeleteBill_Click" Margin="8,0,0,0" ToolTip="Delete selected bill" />
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Padding="6" Background="{DynamicResource PanelBackgroundBrush}">
                    <DataGrid x:Name="BillsGrid"
                              AutoGenerateColumns="False"
                              MinHeight="200"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              IsReadOnly="False"
                              BeginningEdit="BillsGrid_BeginningEdit"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              Margin="0,0,0,0"
                              Background="{DynamicResource ControlBackgroundBrush}"
                              Foreground="{DynamicResource ControlForegroundBrush}"
                              CanUserSortColumns="True"
                              AlternationCount="2">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#554C8DFF"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                        <Setter Property="Background" Value="#5532CD32"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPastDue}" Value="True">
                                        <Setter Property="Background" Value="#55FF6B6B"/>
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPaid}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#8832CD32"/>
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsPastDue}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsSelected}" Value="True"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Background" Value="#88FF6B6B"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Edit" Click="EditBill_Click"/>
                                <MenuItem Header="Delete" Click="DeleteBill_Click"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" SortMemberPath="Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=Explicit}" Width="*" EditingElementStyle="{StaticResource GridTextEditStyle}"/>
                            <DataGridTextColumn Header="Amount" SortMemberPath="Amount" Binding="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=Explicit, StringFormat=N2}" Width="110" ElementStyle="{StaticResource RightAlignedCell}" EditingElementStyle="{StaticResource GridTextEditStyle}"/>
                            <DataGridComboBoxColumn Header="Category"
                                                    SortMemberPath="Category"
                                                    Width="140"
                                                    ItemsSource="{StaticResource BillCategories}"
                                                    SelectedItemBinding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
                                                    EditingElementStyle="{StaticResource GridComboEditStyle}"/>
                            <DataGridTemplateColumn Header="Due Date" SortMemberPath="DueDate" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DueDate, StringFormat=MM/dd/yyyy}" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding DueDate, Mode=OneWay, StringFormat=MM/dd/yyyy}"
                                                 VerticalContentAlignment="Center"
                                                 Padding="4,2"
                                                 ToolTip="Use MM/DD/YYYY"
                                                 Style="{StaticResource GridDueDateEditStyle}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Status" Width="90" SortMemberPath="IsPaid" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent" Cursor="Hand" MouseLeftButtonUp="StatusCell_MouseLeftButtonUp">
                                            <TextBlock x:Name="StatusTxt" Text="Due" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource HintForegroundBrush}"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsPastDue}" Value="True">
                                                <Setter TargetName="StatusTxt" Property="Text" Value="PAST DUE"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="#CC4444"/>
                                                <Setter TargetName="StatusTxt" Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPaid}" Value="True">
                                                <Setter TargetName="StatusTxt" Property="Text" Value="PAID"/>
                                                <Setter TargetName="StatusTxt" Property="Foreground" Value="MediumSeaGreen"/>
                                                <Setter TargetName="StatusTxt" Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Margin="0,10,0,0" BorderBrush="{DynamicResource NotesAreaBorderBrush}" BorderThickness="1" CornerRadius="4" Background="{DynamicResource NotesAreaBackgroundBrush}" Padding="8">
                    <StackPanel>
                        <TextBlock Text="Notes" FontWeight="Bold" Margin="0,0,0,6" Foreground="{DynamicResource NotesHeaderBrush}"/>
                        <TextBox x:Name="NotesBox"
                                 AcceptsReturn="True"
                                 Height="220"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{StaticResource NotebookPaperBrush}"
                                 BorderBrush="{DynamicResource NotesAreaBorderBrush}"
                                 Foreground="{DynamicResource NotesTextBrush}"
                                 SnapsToDevicePixels="True"
                                 UseLayoutRounding="True"
                                 Padding="8,2,8,2"
                                 TextChanged="NotesBox_TextChanged"
                                 LostFocus="NotesBox_LostFocus"/>
                    </StackPanel>
                </Border>

            </Grid>

            <!-- Right area: pie chart and legend -->
            <StackPanel Grid.Column="1" Margin="0">
                <TextBlock Text="Expenses" Style="{StaticResource SectionHeader}"/>
                <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Padding="8" CornerRadius="4" Background="{DynamicResource PanelBackgroundBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,6,0,0">
                            <Canvas x:Name="PieChartCanvas" Width="300" Height="300" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Grid.Row="1" VerticalAlignment="Center">
                            <Border Background="{DynamicResource ControlBackgroundBrush}" Width="160" Height="18" CornerRadius="3">
                                <Rectangle x:Name="ExpenseBar" Height="18" Fill="{DynamicResource ExpenseBarBrush}" HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Text="  Usage" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{DynamicResource HintForegroundBrush}"/>
                        </StackPanel>

                        <StackPanel x:Name="PieLegendPanel" Grid.Row="2" Margin="0,10,0,0"/>
                    </Grid>
                </Border>
                <Button x:Name="BackButton" Content="← Back to Categories" Click="BackButton_Click" Style="{StaticResource ToolbarButton}" Margin="0,10,0,0" Visibility="Collapsed"/>
                <TextBlock Text="Tip: Select a bill and use Edit/Delete for quick changes." Foreground="{DynamicResource HintForegroundBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>