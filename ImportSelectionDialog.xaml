<Window x:Class="CrispyBills.ImportSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Import Scope"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="640"
        MinHeight="480"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource WindowForegroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Choose the years, months, and notes to import from the CSV file."
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Select All" Width="110" Margin="0,0,8,0" Click="SelectAll_Click"/>
            <Button Content="Clear All" Width="110" Margin="0,0,8,0" Click="ClearAll_Click"/>
            <CheckBox x:Name="ImportNotesCheckBox"
                      Content="Import notes"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="YearPanel" Margin="10"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Import" Width="110" Margin="0,0,8,0" Click="Import_Click"/>
            <Button Content="Cancel" Width="100" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>